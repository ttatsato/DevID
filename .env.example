DATABASE_URL=postgres://yokogushi:yokogushi@localhost:5434/yokogushi
RUST_LOG=yokogushi_api=info,tower_http=info,sqlx=warn

# GitHub OAuth (https://github.com/settings/developers)
# Authorization callback URL に GITHUB_REDIRECT_URL と同じ値を設定すること
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:3000/api/auth/github/callback
FRONTEND_URL=http://localhost:3000
